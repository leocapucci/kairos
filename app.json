{
  "expo": {
    "name": "kairos",
    "slug": "kairos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "updates": {
      "enabled": false
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kairos.app"
    },
    "android": {
      "package": "com.kairos.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@sentry/react-native",
      "expo-notifications",
      "expo-web-browser"
    ],
    "scheme": "kairos",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c28e69ec-0e84-4f32-b24c-e4195a18407e"
      }
    }
  }
}
